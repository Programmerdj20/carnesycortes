---
interface Props {
  nombre: string;
  texto: string;
  rating: number;
  imagen?: string;
}

const { nombre, texto, rating, imagen } = Astro.props;
---

<div class="bg-white rounded-2xl p-6 shadow-premium-sm border border-gray-100 hover:shadow-premium-md transition-shadow duration-300">
  <div class="flex items-center gap-1 mb-4">
    {Array.from({ length: 5 }).map((_, i) => (
      <svg class:list={['w-5 h-5', i < rating ? 'text-gold' : 'text-gray-200']} fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
      </svg>
    ))}
  </div>
  <p class="text-gray-600 leading-relaxed mb-6 italic">"{texto}"</p>
  <div class="flex items-center gap-3">
    {imagen ? (
      <img src={imagen} alt={nombre} class="w-10 h-10 rounded-full object-cover" />
    ) : (
      <div class="w-10 h-10 rounded-full bg-brand-red/10 flex items-center justify-center">
        <span class="text-brand-red font-bold text-sm">{nombre.charAt(0)}</span>
      </div>
    )}
    <span class="font-semibold text-gray-900 text-sm">{nombre}</span>
  </div>
</div>
