---
interface Props {
  id: number;
  nombre: string;
  descripcion: string;
  precio: number;
  imagen: string;
  categoria: string;
  peso: string;
  slug: string;
  destacado?: boolean;
}

const { id, nombre, descripcion, precio, imagen, categoria, peso, slug, destacado } = Astro.props;

const categoriaBadgeColors: Record<string, string> = {
  premium: 'bg-gold text-dark-900',
  tradicional: 'bg-brand-red text-white',
  combo: 'bg-green-600 text-white',
  especial: 'bg-purple-600 text-white',
  especialidad: 'bg-dark-800 text-white',
};

const badgeClass = categoriaBadgeColors[categoria] || 'bg-brand-red text-white';
---

<article class="product-card group bg-white rounded-2xl overflow-hidden shadow-premium-sm hover:shadow-premium-lg transition-all duration-500 hover:-translate-y-2 border border-gray-100" data-category={categoria}>
  <a href={`/producto/${slug}`} class="block">
    <div class="relative overflow-hidden aspect-[4/3]">
      <img
        src={imagen}
        alt={nombre}
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      <!-- Badge categoría -->
      <span class:list={['absolute top-4 left-4 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider', badgeClass]}>
        {categoria}
      </span>
      {destacado && (
        <span class="absolute top-4 right-4 bg-gold text-dark-900 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider flex items-center gap-1">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          Destacado
        </span>
      )}
      <!-- Hover overlay con botón ver -->
      <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-500">
        <span class="bg-white text-dark-900 px-6 py-2.5 rounded-full font-semibold text-sm shadow-lg transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
          Ver Detalles
        </span>
      </div>
    </div>
  </a>
  <div class="p-5">
    <a href={`/producto/${slug}`} class="block">
      <h3 class="text-lg font-bold text-gray-900 mb-1 group-hover:text-brand-red transition-colors">{nombre}</h3>
    </a>
    <p class="text-gray-500 text-sm mb-3 line-clamp-2">{descripcion}</p>
    <div class="flex items-center justify-between">
      <div>
        <span class="text-xl font-bold text-brand-red">${precio.toLocaleString('es-CO')}</span>
        <span class="text-gray-400 text-xs block">{peso}</span>
      </div>
      <button
        class="add-to-cart-btn flex items-center gap-1.5 bg-brand-red text-white px-4 py-2 rounded-full text-sm font-semibold hover:bg-brand-red-dark transition-all duration-300 hover:shadow-red-glow"
        data-product-id={id}
        data-product-name={nombre}
        data-product-price={precio}
        data-product-image={imagen}
        data-product-weight={peso}
        data-product-slug={slug}>
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
        </svg>
        Agregar
      </button>
    </div>
  </div>
</article>
