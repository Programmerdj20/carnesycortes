---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  currentPath?: string;
}

const { title, description = "Carnes & Cortes - Cortes especializados premium desde 2009", currentPath = Astro.url.pathname } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="description" content={description} />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Fonts: Inter + Playfair Display -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,700&display=swap" rel="stylesheet">

  <!-- SEO Meta Tags -->
  <meta name="keywords" content="carnes premium, cortes especializados, carne de res, domicilios, carnicería" />
  <meta name="author" content="Carnes & Cortes" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />

  <title>{title}</title>
</head>
<body class="antialiased">
  <Header currentPath={currentPath} />

  <main>
    <slot />
  </main>

  <Footer />

  <!-- Modal del Carrito Global -->
  <div id="globalCartModal" class="fixed inset-0 z-[60] hidden">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="cartOverlay"></div>
    <div class="fixed right-0 top-0 h-full w-full max-w-md bg-white shadow-2xl transform translate-x-full transition-transform duration-300" id="cartSlidePanel">
      <div class="flex flex-col h-full">
        <!-- Header del Carrito -->
        <div class="p-6 border-b border-gray-100 bg-gray-50/80">
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-xl font-display font-bold text-gray-900">Mi Carrito</h2>
              <p class="text-gray-500 text-sm mt-0.5">Productos seleccionados</p>
            </div>
            <button onclick="toggleGlobalCart()" class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-gray-400 hover:text-gray-600 hover:bg-gray-200 transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
        </div>

        <!-- Lista de productos del carrito -->
        <div class="flex-1 overflow-y-auto p-6" id="globalCartItems">
          <div class="text-center text-gray-400 py-12">
            <svg class="w-16 h-16 mx-auto mb-4 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
            </svg>
            <p class="font-medium">Tu carrito está vacío</p>
            <p class="text-sm mt-1">Agrega algunos productos deliciosos</p>
          </div>
        </div>

        <!-- Footer del Carrito -->
        <div class="border-t border-gray-100 p-6 bg-gray-50/80">
          <div class="flex items-center justify-between mb-4">
            <span class="text-gray-600 font-medium">Total:</span>
            <span class="text-2xl font-bold text-brand-red" id="globalCartTotal">$0</span>
          </div>
          <div class="space-y-3">
            <button onclick="sendGlobalWhatsAppOrder()" class="w-full bg-green-600 text-white py-3.5 px-6 rounded-full font-semibold hover:bg-green-700 transition-all duration-300 flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed" id="globalCheckoutBtn" disabled>
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
              </svg>
              Pedir por WhatsApp
            </button>
            <a href="/tienda" onclick="toggleGlobalCart()" class="w-full bg-gray-100 text-gray-700 py-3 px-6 rounded-full font-semibold hover:bg-gray-200 transition-colors flex items-center justify-center gap-2 text-sm">
              Seguir comprando
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Notification toast -->
  <div id="notificationContainer" class="fixed top-24 right-4 z-[70] space-y-2"></div>

  <script>
    // Sistema de carrito global
    let globalCart = JSON.parse(localStorage.getItem('carrito') || '[]');

    function updateGlobalCartDisplay() {
      const cartCount = globalCart.reduce((total, item) => total + item.cantidad, 0);
      const cartTotal = globalCart.reduce((total, item) => total + (item.precio * item.cantidad), 0);

      const cartCountElement = document.getElementById('cartCount');
      if (cartCountElement) {
        cartCountElement.textContent = cartCount.toString();
        cartCountElement.style.display = cartCount > 0 ? 'flex' : 'none';
      }

      const globalCartTotalElement = document.getElementById('globalCartTotal');
      if (globalCartTotalElement) {
        globalCartTotalElement.textContent = `$${cartTotal.toLocaleString('es-CO')}`;
      }

      const globalCartItems = document.getElementById('globalCartItems');
      if (globalCartItems) {
        if (globalCart.length === 0) {
          globalCartItems.innerHTML = `
            <div class="text-center text-gray-400 py-12">
              <svg class="w-16 h-16 mx-auto mb-4 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
              </svg>
              <p class="font-medium">Tu carrito está vacío</p>
              <p class="text-sm mt-1">Agrega algunos productos deliciosos</p>
            </div>
          `;
          document.getElementById('globalCheckoutBtn').disabled = true;
        } else {
          globalCartItems.innerHTML = globalCart.map(item => `
            <div class="flex items-center gap-4 p-3 bg-gray-50 rounded-xl mb-3 transition-all duration-300">
              <img src="${item.imagen}" alt="${item.nombre}" class="w-16 h-16 object-cover rounded-lg flex-shrink-0">
              <div class="flex-1 min-w-0">
                <h4 class="font-semibold text-gray-900 text-sm truncate">${item.nombre}</h4>
                <p class="text-xs text-gray-500">${item.peso || ''}</p>
                <p class="text-brand-red font-bold text-sm">$${item.precio.toLocaleString('es-CO')}</p>
              </div>
              <div class="flex items-center gap-1.5 flex-shrink-0">
                <button onclick="updateGlobalQuantity(${item.id}, -1)" class="w-7 h-7 bg-white border border-gray-200 text-gray-600 rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors text-sm">-</button>
                <span class="w-7 text-center font-semibold text-sm">${item.cantidad}</span>
                <button onclick="updateGlobalQuantity(${item.id}, 1)" class="w-7 h-7 bg-brand-red text-white rounded-full flex items-center justify-center hover:bg-brand-red-dark transition-colors text-sm">+</button>
              </div>
            </div>
          `).join('');
          document.getElementById('globalCheckoutBtn').disabled = false;
        }
      }

      localStorage.setItem('carrito', JSON.stringify(globalCart));
    }

    function addToGlobalCart(producto) {
      const existingItem = globalCart.find(item => item.id === producto.id);

      if (existingItem) {
        existingItem.cantidad += 1;
      } else {
        globalCart.push({...producto, cantidad: 1});
      }

      updateGlobalCartDisplay();
      showNotification(`${producto.nombre} agregado al carrito`);
    }

    function updateGlobalQuantity(productId, change) {
      const item = globalCart.find(item => item.id === productId);
      if (item) {
        item.cantidad += change;
        if (item.cantidad <= 0) {
          globalCart = globalCart.filter(item => item.id !== productId);
        }
        updateGlobalCartDisplay();
      }
    }

    function toggleGlobalCart() {
      const modal = document.getElementById('globalCartModal');
      const panel = document.getElementById('cartSlidePanel');

      if (modal.classList.contains('hidden')) {
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        requestAnimationFrame(() => {
          panel.style.transform = 'translateX(0)';
        });
      } else {
        panel.style.transform = 'translateX(100%)';
        document.body.style.overflow = '';
        setTimeout(() => {
          modal.classList.add('hidden');
        }, 300);
      }
    }

    function sendGlobalWhatsAppOrder() {
      if (globalCart.length === 0) return;

      let message = "🥩 *PEDIDO CARNES & CORTES*\n\n";
      message += "📋 *Productos:*\n";

      globalCart.forEach(item => {
        message += `• ${item.nombre} ${item.peso ? `(${item.peso})` : ''}\n`;
        message += `  Cantidad: ${item.cantidad}\n`;
        message += `  Precio: $${item.precio.toLocaleString('es-CO')} c/u\n`;
        message += `  Subtotal: $${(item.precio * item.cantidad).toLocaleString('es-CO')}\n\n`;
      });

      const total = globalCart.reduce((total, item) => total + (item.precio * item.cantidad), 0);
      message += `💰 *Total: $${total.toLocaleString('es-CO')}*\n\n`;
      message += "📍 Por favor confirmen disponibilidad y tiempo de entrega.";

      const whatsappUrl = `https://wa.me/5573001234567?text=${encodeURIComponent(message)}`;
      window.open(whatsappUrl, '_blank');
    }

    function showNotification(message) {
      const container = document.getElementById('notificationContainer');
      const notification = document.createElement('div');
      notification.className = 'bg-dark-900 text-white px-5 py-3 rounded-full shadow-premium-lg text-sm font-medium flex items-center gap-2 transform translate-x-full opacity-0 transition-all duration-300';
      notification.innerHTML = `
        <svg class="w-4 h-4 text-green-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
        ${message}
      `;
      container.appendChild(notification);

      requestAnimationFrame(() => {
        notification.style.transform = 'translateX(0)';
        notification.style.opacity = '1';
      });

      setTimeout(() => {
        notification.style.transform = 'translateX(100%)';
        notification.style.opacity = '0';
        setTimeout(() => notification.remove(), 300);
      }, 3000);
    }

    // Hacer funciones globalmente disponibles
    window.globalCart = globalCart;
    window.addToGlobalCart = addToGlobalCart;
    window.updateGlobalQuantity = updateGlobalQuantity;
    window.toggleGlobalCart = toggleGlobalCart;
    window.sendGlobalWhatsAppOrder = sendGlobalWhatsAppOrder;
    window.updateGlobalCartDisplay = updateGlobalCartDisplay;
    window.showNotification = showNotification;

    // Click en botón del carrito
    document.getElementById('cartBtn')?.addEventListener('click', toggleGlobalCart);

    // Click en overlay cierra carrito
    document.getElementById('cartOverlay')?.addEventListener('click', toggleGlobalCart);

    // Click en botones "add-to-cart" via event delegation
    document.addEventListener('click', (e) => {
      const btn = e.target.closest('.add-to-cart-btn');
      if (btn) {
        e.preventDefault();
        const producto = {
          id: parseInt(btn.dataset.productId),
          nombre: btn.dataset.productName,
          precio: parseInt(btn.dataset.productPrice),
          imagen: btn.dataset.productImage,
          peso: btn.dataset.productWeight,
          slug: btn.dataset.productSlug,
        };
        addToGlobalCart(producto);
      }
    });

    // Inicializar
    updateGlobalCartDisplay();

    // Reveal on scroll - Intersection Observer
    const revealElements = document.querySelectorAll('.reveal-on-scroll');
    if (revealElements.length > 0) {
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

      revealElements.forEach(el => revealObserver.observe(el));
    }
  </script>
</body>
</html>
