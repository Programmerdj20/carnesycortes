---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Carnes & Cortes - Cortes especializados premium desde 2009" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="description" content={description} />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- SEO Meta Tags -->
  <meta name="keywords" content="carnes premium, cortes especializados, carne de res, domicilios, carnicería" />
  <meta name="author" content="Carnes & Cortes" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  
  <title>{title}</title>
</head>
<body>
  <header class="fixed top-0 left-0 right-0 bg-white/95 backdrop-blur-md border-b border-brand-red/10 z-50">
    <nav class="py-4">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between">
          <div>
            <a href="/" class="block">
              <img src="/Assets/Logo cc.png" alt="Carnes & Cortes" class="h-12 w-auto transition-transform duration-300 hover:scale-105" />
            </a>
          </div>
          
          <div class="hidden md:flex items-center space-x-8" id="navMenu">
            <a href="/" class="text-gray-700 font-medium hover:text-brand-red transition-colors duration-300 relative group">
              Inicio
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-red transition-all duration-300 group-hover:w-full"></span>
            </a>
            <a href="/productos" class="text-gray-700 font-medium hover:text-brand-red transition-colors duration-300 relative group">
              Productos
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-red transition-all duration-300 group-hover:w-full"></span>
            </a>
            <a href="/combos" class="text-gray-700 font-medium hover:text-brand-red transition-colors duration-300 relative group">
              Combos
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-red transition-all duration-300 group-hover:w-full"></span>
            </a>
            <a href="/nosotros" class="text-gray-700 font-medium hover:text-brand-red transition-colors duration-300 relative group">
              Nosotros
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-red transition-all duration-300 group-hover:w-full"></span>
            </a>
            <a href="/contacto" class="text-gray-700 font-medium hover:text-brand-red transition-colors duration-300 relative group">
              Contacto
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-red transition-all duration-300 group-hover:w-full"></span>
            </a>
          </div>
          
          <div class="flex items-center space-x-4">
            <button class="relative p-2 border-2 border-brand-red text-brand-red rounded-lg hover:bg-brand-red hover:text-white transition-all duration-300" id="cartBtn">
              <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4m2.6 8L6 7H2m5 6v6a1 1 0 001 1h10a1 1 0 001-1v-6m-9 0V9a1 1 0 011-1h4a1 1 0 011 1v4"></path>
              </svg>
              <span class="absolute -top-2 -right-2 bg-brand-red text-white rounded-full w-5 h-5 flex items-center justify-center text-xs font-bold" id="cartCount">0</span>
            </button>
            
            <a href="/tienda" 
               class="hidden sm:flex items-center gap-2 bg-brand-red text-white px-4 py-2 rounded-lg font-semibold hover:bg-brand-red-dark transition-all duration-300 hover:-translate-y-0.5 shadow-lg">
              <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
              </svg>
              Hacer Pedido
            </a>
            
            <button class="md:hidden flex flex-col p-2 space-y-1 focus:outline-none" id="menuToggle">
              <span class="w-6 h-0.5 bg-brand-red transition-all duration-300"></span>
              <span class="w-6 h-0.5 bg-brand-red transition-all duration-300"></span>
              <span class="w-6 h-0.5 bg-brand-red transition-all duration-300"></span>
            </button>
          </div>
        </div>
      </div>
    </nav>
  </header>

  <main class="pt-20">
    <slot />
  </main>

  <footer class="bg-gray-900 text-white py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Footer principal -->
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8 mb-8">
        <!-- Logo y descripción -->
        <div class="flex flex-col md:flex-row md:items-center gap-6">
          <img src="/Assets/Logo cc.png" alt="Carnes & Cortes" class="h-12 w-auto" />
          <div class="text-center md:text-left">
            <p class="text-gray-300 text-sm leading-relaxed max-w-md">
              Cortes especializados premium desde 2009. Calidad garantizada en cada entrega.
            </p>
          </div>
        </div>
        
        <!-- Contacto -->
        <div class="text-center md:text-right">
          <a href="https://wa.me/5573001234567" 
             class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-500 text-white px-6 py-3 rounded-lg font-semibold transition-all duration-300 hover:-translate-y-0.5 shadow-lg">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
            </svg>
            +57 300 123 4567
          </a>
          <div class="text-gray-400 text-xs mt-2">Lunes a Domingo • 8:00 AM - 8:00 PM</div>
        </div>
      </div>
      
      <!-- Copyright -->
      <div class="border-t border-gray-700 pt-6 text-center">
        <p class="text-gray-400 text-sm">&copy; 2024 Carnes & Cortes. Todos los derechos reservados.</p>
      </div>
    </div>
  </footer>

  <!-- Modal del Carrito Global -->
  <div id="globalCartModal" class="fixed inset-0 bg-black/50 z-50 hidden">
    <div class="fixed right-0 top-0 h-full w-full max-w-md bg-white shadow-xl">
      <div class="flex flex-col h-full">
        <!-- Header del Carrito -->
        <div class="p-6 border-b border-gray-200">
          <div class="flex items-center justify-between">
            <h2 class="text-2xl font-bold text-gray-900">Mi Carrito</h2>
            <button onclick="toggleGlobalCart()" class="text-gray-400 hover:text-gray-600">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
          <p class="text-gray-600 mt-1">Productos seleccionados</p>
        </div>

        <!-- Lista de productos del carrito -->
        <div class="flex-1 overflow-y-auto p-6" id="globalCartItems">
          <div class="text-center text-gray-500 py-8">
            <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4m2.6 8L6 5H2m5 8v6a1 1 0 001 1h10a1 1 0 001-1v-6m-9 0V9a1 1 0 011-1h4a1 1 0 011 1v4"></path>
            </svg>
            <p>Tu carrito está vacío</p>
            <p class="text-sm mt-2">¡Agrega algunos productos deliciosos!</p>
          </div>
        </div>

        <!-- Footer del Carrito -->
        <div class="border-t border-gray-200 p-6">
          <div class="flex items-center justify-between mb-4">
            <span class="text-lg font-semibold text-gray-900">Total:</span>
            <span class="text-2xl font-bold text-brand-red" id="globalCartTotal">$0</span>
          </div>
          <div class="space-y-3">
            <a href="/tienda" onclick="toggleGlobalCart()" class="w-full bg-brand-red text-white py-3 px-6 rounded-lg font-semibold hover:bg-brand-red-dark transition-colors flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
              </svg>
              Ir a la Tienda
            </a>
            <button onclick="sendGlobalWhatsAppOrder()" class="w-full bg-green-600 text-white py-3 px-6 rounded-lg font-semibold hover:bg-green-700 transition-colors flex items-center justify-center gap-2" id="globalCheckoutBtn" disabled>
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
              </svg>
              Hacer Pedido por WhatsApp
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Sistema de carrito global
    let globalCart = JSON.parse(localStorage.getItem('carrito') || '[]');

    // Toggle mobile menu
    const menuToggle = document.getElementById('menuToggle');
    const navMenu = document.getElementById('navMenu');
    
    menuToggle?.addEventListener('click', () => {
      navMenu?.classList.toggle('active');
      menuToggle.classList.toggle('active');
    });

    // Funciones globales del carrito
    function updateGlobalCartDisplay() {
      const cartCount = globalCart.reduce((total, item) => total + item.cantidad, 0);
      const cartTotal = globalCart.reduce((total, item) => total + (item.precio * item.cantidad), 0);
      
      // Actualizar contador del navbar
      const cartCountElement = document.getElementById('cartCount');
      if (cartCountElement) {
        cartCountElement.textContent = cartCount.toString();
      }
      
      // Actualizar total del modal
      const globalCartTotalElement = document.getElementById('globalCartTotal');
      if (globalCartTotalElement) {
        globalCartTotalElement.textContent = `$${cartTotal.toLocaleString('es-CO')}`;
      }
      
      // Actualizar lista de productos
      const globalCartItems = document.getElementById('globalCartItems');
      if (globalCartItems) {
        if (globalCart.length === 0) {
          globalCartItems.innerHTML = `
            <div class="text-center text-gray-500 py-8">
              <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4m2.6 8L6 5H2m5 8v6a1 1 0 001 1h10a1 1 0 001-1v-6m-9 0V9a1 1 0 011-1h4a1 1 0 011 1v4"></path>
              </svg>
              <p>Tu carrito está vacío</p>
              <p class="text-sm mt-2">¡Agrega algunos productos deliciosos!</p>
            </div>
          `;
          document.getElementById('globalCheckoutBtn').disabled = true;
        } else {
          globalCartItems.innerHTML = globalCart.map(item => `
            <div class="flex items-center gap-4 p-4 border border-gray-200 rounded-lg mb-4">
              <img src="${item.imagen}" alt="${item.nombre}" class="w-16 h-16 object-cover rounded-lg">
              <div class="flex-1">
                <h4 class="font-semibold text-gray-900">${item.nombre}</h4>
                <p class="text-sm text-gray-600">${item.peso || ''}</p>
                <p class="text-brand-red font-bold">$${item.precio.toLocaleString('es-CO')}</p>
              </div>
              <div class="flex items-center gap-2">
                <button onclick="updateGlobalQuantity(${item.id}, -1)" class="w-8 h-8 bg-gray-200 text-gray-700 rounded-full flex items-center justify-center hover:bg-gray-300 transition-colors">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path>
                  </svg>
                </button>
                <span class="w-8 text-center font-semibold">${item.cantidad}</span>
                <button onclick="updateGlobalQuantity(${item.id}, 1)" class="w-8 h-8 bg-brand-red text-white rounded-full flex items-center justify-center hover:bg-brand-red-dark transition-colors">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                  </svg>
                </button>
              </div>
            </div>
          `).join('');
          document.getElementById('globalCheckoutBtn').disabled = false;
        }
      }
      
      // Guardar en localStorage
      localStorage.setItem('carrito', JSON.stringify(globalCart));
    }

    function addToGlobalCart(producto) {
      const existingItem = globalCart.find(item => item.id === producto.id);
      
      if (existingItem) {
        existingItem.cantidad += 1;
      } else {
        globalCart.push({...producto, cantidad: 1});
      }
      
      updateGlobalCartDisplay();
    }

    function updateGlobalQuantity(productId, change) {
      const item = globalCart.find(item => item.id === productId);
      if (item) {
        item.cantidad += change;
        if (item.cantidad <= 0) {
          globalCart = globalCart.filter(item => item.id !== productId);
        }
        updateGlobalCartDisplay();
      }
    }

    function toggleGlobalCart() {
      const modal = document.getElementById('globalCartModal');
      modal.classList.toggle('hidden');
    }

    function sendGlobalWhatsAppOrder() {
      if (globalCart.length === 0) return;
      
      let message = "🥩 *PEDIDO CARNES & CORTES*\n\n";
      message += "📋 *Productos:*\n";
      
      globalCart.forEach(item => {
        message += `• ${item.nombre} ${item.peso ? `(${item.peso})` : ''}\n`;
        message += `  Cantidad: ${item.cantidad}\n`;
        message += `  Precio: $${item.precio.toLocaleString('es-CO')} c/u\n`;
        message += `  Subtotal: $${(item.precio * item.cantidad).toLocaleString('es-CO')}\n\n`;
      });
      
      const total = globalCart.reduce((total, item) => total + (item.precio * item.cantidad), 0);
      message += `💰 *Total: $${total.toLocaleString('es-CO')}*\n\n`;
      message += "📍 Por favor confirmen disponibilidad y tiempo de entrega.";
      
      const whatsappUrl = `https://wa.me/5573001234567?text=${encodeURIComponent(message)}`;
      window.open(whatsappUrl, '_blank');
    }

    // Hacer funciones globalmente disponibles
    window.globalCart = globalCart;
    window.addToGlobalCart = addToGlobalCart;
    window.updateGlobalQuantity = updateGlobalQuantity;
    window.toggleGlobalCart = toggleGlobalCart;
    window.sendGlobalWhatsAppOrder = sendGlobalWhatsAppOrder;
    window.updateGlobalCartDisplay = updateGlobalCartDisplay;
    
    // Evento click en el botón del carrito del navbar
    document.getElementById('cartBtn')?.addEventListener('click', toggleGlobalCart);
    
    // Inicializar display del carrito
    updateGlobalCartDisplay();
  </script>
</body>
</html>

