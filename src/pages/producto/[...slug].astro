---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import NutritionTable from '../../components/NutritionTable.astro';
import ProductCard from '../../components/ProductCard.astro';

export async function getStaticPaths() {
  const productos = await getCollection('productos');
  return productos.map(producto => ({
    params: { slug: producto.data.slug },
    props: { producto: producto.data },
  }));
}

const { producto } = Astro.props;

const todosLosProductos = await getCollection('productos');
const relacionados = todosLosProductos
  .filter(p => p.data.categoria === producto.categoria && p.data.id !== producto.id)
  .slice(0, 4);

const categoriaLabel: Record<string, string> = {
  premium: 'Premium',
  tradicional: 'Tradicional',
  combo: 'Combo',
  especial: 'Especial',
  especialidad: 'Especialidad',
};
---

<Layout title={`${producto.nombre} - Carnes & Cortes`} description={producto.descripcion}>
  <!-- Hero / Breadcrumb -->
  <section class="bg-dark-900 pt-28 pb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[
        { label: 'Inicio', href: '/' },
        { label: 'Tienda', href: '/tienda' },
        { label: categoriaLabel[producto.categoria] || producto.categoria, href: `/tienda?cat=${producto.categoria}` },
        { label: producto.nombre },
      ]} />
    </div>
  </section>

  <!-- Producto Principal -->
  <section class="bg-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Galería -->
        <div class="space-y-4">
          <div class="aspect-square rounded-2xl overflow-hidden bg-gray-100">
            <img
              src={producto.imagen}
              alt={producto.nombre}
              class="w-full h-full object-cover"
              loading="eager"
              id="mainImage"
            />
          </div>
        </div>

        <!-- Info principal -->
        <div class="flex flex-col">
          <!-- Badge categoría -->
          <div class="flex items-center gap-3 mb-4">
            <span class="bg-brand-red/10 text-brand-red px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider">
              {categoriaLabel[producto.categoria] || producto.categoria}
            </span>
            {producto.stock && (
              <span class="bg-green-50 text-green-600 px-3 py-1 rounded-full text-xs font-bold flex items-center gap-1">
                <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
                En Stock
              </span>
            )}
          </div>

          <!-- Nombre y precio -->
          <h1 class="text-3xl sm:text-4xl font-display font-bold text-gray-900 mb-2">{producto.nombre}</h1>
          <div class="flex items-baseline gap-3 mb-6">
            <span class="text-3xl font-bold text-brand-red">${producto.precio.toLocaleString('es-CO')}</span>
            <span class="text-gray-400 text-sm">/ {producto.peso}</span>
          </div>

          <!-- Descripción -->
          <p class="text-gray-600 leading-relaxed mb-8">{producto.descripcion}</p>

          <!-- Características rápidas -->
          <div class="grid grid-cols-2 gap-4 mb-8">
            {producto.origen && (
              <div class="bg-gray-50 rounded-xl p-4">
                <span class="text-xs text-gray-500 uppercase tracking-wider">Origen</span>
                <p class="font-semibold text-gray-900 text-sm mt-1">{producto.origen}</p>
              </div>
            )}
            {producto.maduracion && (
              <div class="bg-gray-50 rounded-xl p-4">
                <span class="text-xs text-gray-500 uppercase tracking-wider">Maduración</span>
                <p class="font-semibold text-gray-900 text-sm mt-1">{producto.maduracion}</p>
              </div>
            )}
            {producto.grado && (
              <div class="bg-gray-50 rounded-xl p-4">
                <span class="text-xs text-gray-500 uppercase tracking-wider">Grado</span>
                <p class="font-semibold text-gray-900 text-sm mt-1">{producto.grado}</p>
              </div>
            )}
            <div class="bg-gray-50 rounded-xl p-4">
              <span class="text-xs text-gray-500 uppercase tracking-wider">Peso</span>
              <p class="font-semibold text-gray-900 text-sm mt-1">{producto.peso}</p>
            </div>
          </div>

          <!-- Cantidad y Agregar -->
          <div class="flex items-center gap-4 mb-6">
            <div class="flex items-center border-2 border-gray-200 rounded-full overflow-hidden">
              <button onclick="changeQty(-1)" class="w-12 h-12 flex items-center justify-center text-gray-600 hover:bg-gray-50 transition-colors text-lg font-bold">-</button>
              <span id="productQty" class="w-12 h-12 flex items-center justify-center font-bold text-gray-900 border-x-2 border-gray-200">1</span>
              <button onclick="changeQty(1)" class="w-12 h-12 flex items-center justify-center text-gray-600 hover:bg-gray-50 transition-colors text-lg font-bold">+</button>
            </div>
            <button
              id="addToCartBtn"
              class="flex-1 bg-brand-red text-white py-3.5 px-8 rounded-full font-semibold hover:bg-brand-red-dark transition-all duration-300 shadow-red-glow flex items-center justify-center gap-2 text-lg"
              onclick="addProductToCart()">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
              </svg>
              Agregar al Carrito
            </button>
          </div>

          <!-- WhatsApp directo -->
          <a href={`https://wa.me/5573001234567?text=${encodeURIComponent(`Hola, me interesa el ${producto.nombre} ($${producto.precio.toLocaleString('es-CO')}). ¿Podrían darme más información?`)}`}
             target="_blank"
             rel="noopener noreferrer"
             class="flex items-center justify-center gap-2 bg-green-600 text-white py-3 px-6 rounded-full font-semibold hover:bg-green-500 transition-all duration-300">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
            </svg>
            Consultar por WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Detalles adicionales -->
  <section class="bg-cream py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-8">
        <!-- Preparación -->
        {producto.preparacion && (
          <div class="bg-white rounded-2xl p-6 shadow-premium-sm">
            <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/>
              </svg>
              Preparación Recomendada
            </h3>
            <div class="space-y-3">
              <div class="flex items-start gap-3">
                <span class="w-8 h-8 bg-brand-red/10 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                  </svg>
                </span>
                <div>
                  <span class="font-semibold text-gray-900 text-sm">Método</span>
                  <p class="text-gray-600 text-sm">{producto.preparacion.metodo}</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="w-8 h-8 bg-brand-red/10 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </span>
                <div>
                  <span class="font-semibold text-gray-900 text-sm">Tiempo</span>
                  <p class="text-gray-600 text-sm">{producto.preparacion.tiempo}</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="w-8 h-8 bg-brand-red/10 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                  </svg>
                </span>
                <div>
                  <span class="font-semibold text-gray-900 text-sm">Temperatura</span>
                  <p class="text-gray-600 text-sm">{producto.preparacion.temperatura}</p>
                </div>
              </div>
            </div>

            {producto.preparacion.tips && producto.preparacion.tips.length > 0 && (
              <div class="mt-5 pt-5 border-t border-gray-100">
                <h4 class="font-semibold text-gray-900 text-sm mb-3">Tips:</h4>
                <ul class="space-y-2">
                  {producto.preparacion.tips.map(tip => (
                    <li class="flex items-start gap-2 text-sm text-gray-600">
                      <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                      </svg>
                      {tip}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        )}

        <!-- Nutrición -->
        {producto.nutricion && (
          <NutritionTable nutricion={producto.nutricion} />
        )}
      </div>

      <!-- Maridajes -->
      {producto.maridajes && producto.maridajes.length > 0 && (
        <div class="mt-8 bg-white rounded-2xl p-6 shadow-premium-sm">
          <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
            </svg>
            Maridajes Recomendados
          </h3>
          <div class="flex flex-wrap gap-2">
            {producto.maridajes.map(m => (
              <span class="px-4 py-2 bg-brand-red/5 text-brand-red-dark rounded-full text-sm font-medium border border-brand-red/10">
                {m}
              </span>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Productos Relacionados -->
  {relacionados.length > 0 && (
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-10">
          <div>
            <span class="text-brand-red font-semibold text-sm uppercase tracking-widest">También te puede interesar</span>
            <h2 class="text-2xl sm:text-3xl font-display font-bold text-gray-900 mt-2">Productos Relacionados</h2>
          </div>
          <a href={`/tienda?cat=${producto.categoria}`} class="text-brand-red font-semibold text-sm hover:underline hidden sm:inline-flex items-center gap-1">
            Ver más
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {relacionados.map(p => (
            <ProductCard
              id={p.data.id}
              nombre={p.data.nombre}
              descripcion={p.data.descripcion}
              precio={p.data.precio}
              imagen={p.data.imagen}
              categoria={p.data.categoria}
              peso={p.data.peso}
              slug={p.data.slug}
              destacado={p.data.destacado}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>

<script define:vars={{ productoData: producto }}>
  let qty = 1;

  function changeQty(delta) {
    qty = Math.max(1, qty + delta);
    document.getElementById('productQty').textContent = qty;
  }

  function addProductToCart() {
    const producto = {
      id: productoData.id,
      nombre: productoData.nombre,
      precio: productoData.precio,
      imagen: productoData.imagen,
      peso: productoData.peso,
      slug: productoData.slug,
    };

    // Agregar al carrito con la cantidad seleccionada
    const existingItem = window.globalCart.find(item => item.id === producto.id);
    if (existingItem) {
      existingItem.cantidad += qty;
    } else {
      window.globalCart.push({...producto, cantidad: qty});
    }
    window.updateGlobalCartDisplay();
    window.showNotification(`${producto.nombre} x${qty} agregado al carrito`);
  }

  window.changeQty = changeQty;
  window.addProductToCart = addProductToCart;
</script>
