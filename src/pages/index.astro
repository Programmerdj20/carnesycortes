---
import Layout from '../layouts/Layout.astro';

// Datos de productos de ejemplo (después conectaremos con Supabase)
const productos = [
  {
    id: 1,
    nombre: "Ribeye Premium",
    descripcion: "Corte premium con excelente marmoleo, perfecto para asados especiales",
    precio: 45000,
    imagen: "/Assets/Banner_1.webp",
    categoria: "premium"
  },
  {
    id: 2,
    nombre: "Filete de Res",
    descripcion: "El corte más tierno, ideal para preparaciones gourmet",
    precio: 52000,
    imagen: "/Assets/Banner_1.webp",
    categoria: "premium"
  },
  {
    id: 3,
    nombre: "New York Strip",
    descripcion: "Corte jugoso con el equilibrio perfecto entre textura y sabor",
    precio: 48000,
    imagen: "/Assets/Banner_1.webp",
    categoria: "premium"
  },
  {
    id: 4,
    nombre: "Tomahawk Steak",
    descripcion: "Corte espectacular para ocasiones especiales, presentación única",
    precio: 85000,
    imagen: "/Assets/Banner_1.webp",
    categoria: "especial"
  },
  {
    id: 5,
    nombre: "Picada Premium",
    descripcion: "Selección de los mejores cortes para compartir (4-6 personas)",
    precio: 120000,
    imagen: "/Assets/Banner_1.webp",
    categoria: "combo"
  },
  {
    id: 6,
    nombre: "Asado Familiar",
    descripcion: "Kit completo para asado familiar con acompañamientos",
    precio: 150000,
    imagen: "/Assets/Banner_1.webp",
    categoria: "combo"
  },
  {
    id: 7,
    nombre: "Parrillada Ejecutiva",
    descripcion: "Combo especial para reuniones de trabajo, incluye cortes selectos y guarniciones gourmet",
    precio: 200000,
    imagen: "/Assets/Banner_1.webp",
    categoria: "combo"
  },
  {
    id: 8,
    nombre: "Combo Romántico",
    descripcion: "Dos filetes premium con acompañamientos especiales para una cena íntima perfecta",
    precio: 95000,
    imagen: "/Assets/Banner_1.webp",
    categoria: "combo"
  },
  {
    id: 9,
    nombre: "Mega Asado",
    descripcion: "Para grandes celebraciones, variedad completa de carnes premium (10-12 personas)",
    precio: 350000,
    imagen: "/Assets/Banner_1.webp",
    categoria: "combo"
  }
];

const combos = productos.filter(p => p.categoria === "combo");
const cortesEspeciales = productos.filter(p => p.categoria === "premium" || p.categoria === "especial");
---

<Layout title="Carnes & Cortes - Cortes Especializados Premium">
  <!-- Hero Section - Premium Modern Design with Tailwind -->
  <section class="relative min-h-screen overflow-hidden flex items-center bg-gradient-to-br from-dark-900 via-dark-800 to-dark-900"
           style="background-image: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), url('/Assets/Banner_1.webp'); background-size: cover; background-position: center; background-attachment: fixed;">
    
    <!-- Animated Background Elements -->
    <div class="absolute inset-0 z-10">
      <!-- Dynamic Gradient Overlay -->
      <div class="absolute inset-0 animate-gradient-flow opacity-60">
        <div class="absolute inset-0 bg-gradient-to-br from-brand-red/15 via-transparent to-brand-red/8"></div>
        <div class="absolute inset-0 bg-gradient-to-tl from-brand-red/10 via-transparent to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/3 to-transparent"></div>
      </div>
      
      <!-- Floating Elements -->
      <div class="absolute inset-0">
        <div class="absolute w-24 h-24 bg-brand-red/8 rounded-full blur-sm animate-float-up-down top-1/4 left-1/4" style="animation-delay: 0s;"></div>
        <div class="absolute w-16 h-16 bg-brand-red/12 rounded-full blur-sm animate-float-up-down top-3/5 right-1/3" style="animation-delay: 2s;"></div>
        <div class="absolute w-12 h-12 bg-white/4 rounded-full blur-sm animate-float-up-down bottom-1/4 left-2/3" style="animation-delay: 4s;"></div>
      </div>
    </div>

    <!-- Main Hero Content -->
    <div class="relative z-30 w-full max-w-7xl mx-auto px-4 sm:px-8 grid lg:grid-cols-2 gap-8 lg:gap-12 items-center min-h-screen py-20">
      
      <!-- Hero Content -->
      <div class="animate-slide-in-left lg:max-w-none max-w-xl mx-auto lg:mx-0 text-center lg:text-left relative z-40">
        <!-- Badge -->
        <div class="relative inline-flex items-center px-6 py-2 mb-6 bg-white/90 border-2 border-brand-red rounded-full shadow-xl">
          <span class="text-brand-red text-xs font-bold tracking-widest uppercase">DESDE 2009</span>
        </div>
        
        <!-- Title -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-black leading-tight mb-6 tracking-tight">
          <div class="text-white font-black mb-1" style="text-shadow: 3px 3px 6px rgba(0,0,0,0.9), 1px 1px 3px rgba(0,0,0,0.8);">CORTES</div>
          <div class="text-white font-black mb-1" style="text-shadow: 3px 3px 6px rgba(0,0,0,0.9), 1px 1px 3px rgba(0,0,0,0.8);">ESPECIALIZADOS</div>
          <div class="text-brand-red font-black" style="text-shadow: 3px 3px 6px rgba(0,0,0,0.9), 1px 1px 3px rgba(0,0,0,0.8), 0 0 20px rgba(196, 30, 58, 0.6);">PREMIUM</div>
        </h1>
        
        <!-- Description -->
        <div class="bg-black/50 backdrop-blur-sm rounded-xl p-5 mb-6 border border-white/20 shadow-xl max-w-md mx-auto lg:mx-0">
          <p class="text-lg sm:text-xl text-white font-medium leading-relaxed" style="text-shadow: 1px 1px 3px rgba(0,0,0,0.9);">
            Experiencia excepcional con los mejores cortes seleccionados.
          </p>
          <p class="text-brand-red font-bold text-lg sm:text-xl mt-3" style="text-shadow: 1px 1px 3px rgba(0,0,0,0.9), 0 0 12px rgba(196, 30, 58, 0.6);">
            Calidad garantizada en cada entrega.
          </p>
        </div>
        
        <!-- Stats -->
        <div class="flex items-center justify-center lg:justify-start gap-4 mb-8 bg-black/60 backdrop-blur-sm rounded-xl px-6 py-6 border border-brand-red/40 shadow-xl max-w-fit">
          <div class="text-center min-w-0 flex-1">
            <div class="text-2xl sm:text-3xl lg:text-4xl font-black text-brand-red leading-none mb-1" style="text-shadow: 1px 1px 3px rgba(0,0,0,0.9), 0 0 10px rgba(196, 30, 58, 0.6);">15+</div>
            <div class="text-xs sm:text-sm text-white font-bold uppercase tracking-wide leading-tight" style="text-shadow: 1px 1px 2px rgba(0,0,0,0.9);">Años experiencia</div>
          </div>
          <div class="w-0.5 h-12 bg-brand-red rounded flex-shrink-0"></div>
          <div class="text-center min-w-0 flex-1">
            <div class="text-2xl sm:text-3xl lg:text-4xl font-black text-brand-red leading-none mb-1" style="text-shadow: 1px 1px 3px rgba(0,0,0,0.9), 0 0 10px rgba(196, 30, 58, 0.6);">100%</div>
            <div class="text-xs sm:text-sm text-white font-bold uppercase tracking-wide leading-tight" style="text-shadow: 1px 1px 2px rgba(0,0,0,0.9);">Calidad garantizada</div>
          </div>
          <div class="w-0.5 h-12 bg-brand-red rounded flex-shrink-0"></div>
          <div class="text-center min-w-0 flex-1">
            <div class="text-2xl sm:text-3xl lg:text-4xl font-black text-brand-red leading-none mb-1" style="text-shadow: 1px 1px 3px rgba(0,0,0,0.9), 0 0 10px rgba(196, 30, 58, 0.6);">24/7</div>
            <div class="text-xs sm:text-sm text-white font-bold uppercase tracking-wide leading-tight" style="text-shadow: 1px 1px 2px rgba(0,0,0,0.9);">Disponibilidad</div>
          </div>
        </div>
        
        <!-- Actions -->
        <div class="flex justify-center lg:justify-start animate-fade-in-up relative z-50" style="animation-delay: 1.4s;">
          <button onclick="scrollToProducts()" 
                  class="group relative flex items-center justify-center gap-3 px-8 py-4 bg-brand-red text-white font-bold text-sm uppercase tracking-wide rounded-xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:bg-brand-red-dark border border-brand-red-light shadow-xl hover:shadow-brand-red/30"
                  style="box-shadow: 0 8px 25px rgba(196, 30, 58, 0.25), inset 0 1px 0 rgba(255,255,255,0.1);">
            <span class="relative z-10 font-bold" style="text-shadow: 1px 1px 2px rgba(0,0,0,0.4);">EXPLORAR PRODUCTOS</span>
            <svg class="relative z-10 w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </button>
        </div>
      </div>
      
      <!-- Hero Visual Area with Floating Cards -->
      <div class="relative h-96 sm:h-[500px] lg:h-full animate-slide-in-right lg:order-none order-first overflow-hidden">
        
        <!-- Decorative Elements -->
        <div class="absolute top-1/4 left-1/3 w-32 h-32 sm:w-48 sm:h-48 border border-brand-red/20 rounded-full animate-rotate-slow opacity-60"></div>
        <div class="absolute bottom-1/4 right-1/4 w-24 h-24 sm:w-32 sm:h-32 border border-brand-red/30 rounded-full animate-rotate-slow opacity-40" style="animation-direction: reverse; animation-duration: 15s;"></div>
        
        <div class="absolute top-1/4 left-1/2 w-2 h-2 bg-brand-red rounded-full animate-pulse-dot opacity-80"></div>
        <div class="absolute bottom-1/3 right-1/3 w-2 h-2 bg-brand-red rounded-full animate-pulse-dot opacity-80" style="animation-delay: 1s;"></div>
        <div class="absolute top-2/3 left-1/4 w-2 h-2 bg-brand-red rounded-full animate-pulse-dot opacity-80" style="animation-delay: 2s;"></div>
      </div>
    </div>

  </section>

  <!-- Productos Destacados -->
  <section class="py-16 bg-gray-50" id="productos">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">Cortes Especializados</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">Selección de nuestros mejores cortes premium</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {cortesEspeciales.map(producto => (
          <article class="bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
            <div class="relative group overflow-hidden aspect-[4/3]">
              <img src={producto.imagen} alt={producto.nombre} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
              <div class="absolute inset-0 bg-black/70 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <button class="bg-brand-red text-white px-6 py-3 rounded-lg font-semibold hover:bg-brand-red-dark transition-colors duration-300" onclick={`openProductModal(${producto.id})`}>
                  Ver Detalles
                </button>
              </div>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">{producto.nombre}</h3>
              <p class="text-gray-600 mb-4 leading-relaxed">{producto.descripcion}</p>
              <div class="flex items-center justify-between">
                <span class="text-2xl font-bold text-brand-red">
                  ${producto.precio.toLocaleString('es-CO')}
                </span>
                <button class="flex items-center gap-2 bg-brand-red text-white px-4 py-2 rounded-lg font-semibold hover:bg-brand-red-dark transition-all duration-300 hover:-translate-y-0.5" onclick={`addProductToCart(${producto.id})`}>
                  <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                  </svg>
                  Agregar
                </button>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Combos y Ofertas - Carrusel -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">Combos Familiares</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">Perfectos para reuniones y celebraciones especiales</p>
      </div>
      
      <!-- Carrusel Container -->
      <div class="relative max-w-4xl mx-auto">
        <!-- Carrusel Wrapper -->
        <div class="overflow-hidden rounded-xl">
          <div id="combosCarousel" class="flex transition-transform duration-500 ease-in-out">
            {combos.map((combo, index) => (
              <div class="w-full flex-shrink-0" key={combo.id}>
                <article class="bg-white rounded-xl overflow-hidden shadow-lg border border-gray-100">
                  <div class="grid md:grid-cols-2 gap-0">
                    <!-- Imagen -->
                    <div class="relative aspect-square md:aspect-auto">
                      <img src={combo.imagen} alt={combo.nombre} class="w-full h-full object-cover" />
                      <span class="absolute top-4 left-4 bg-brand-red text-white px-4 py-2 rounded-lg text-sm font-bold z-10">Combo</span>
                    </div>
                    <!-- Contenido -->
                    <div class="p-8 flex flex-col justify-center">
                      <h3 class="text-3xl font-bold text-gray-900 mb-4">{combo.nombre}</h3>
                      <p class="text-gray-600 mb-6 leading-relaxed text-lg">{combo.descripcion}</p>
                      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
                        <span class="text-4xl font-bold text-brand-red">
                          ${combo.precio.toLocaleString('es-CO')}
                        </span>
                        <button class="bg-brand-red text-white px-8 py-3 rounded-lg font-semibold hover:bg-brand-red-dark transition-all duration-300 hover:-translate-y-0.5 shadow-lg" onclick={`addProductToCart(${combo.id})`}>
                          Agregar al Pedido
                        </button>
                      </div>
                      <!-- Indicadores -->
                      <div class="flex justify-center space-x-2">
                        {combos.map((_, dotIndex) => (
                          <button 
                            class={`w-3 h-3 rounded-full transition-colors duration-300 ${dotIndex === 0 ? 'bg-brand-red' : 'bg-gray-300'}`}
                            onclick={`goToSlide(${dotIndex})`}
                            id={`dot-${dotIndex}`}
                          ></button>
                        ))}
                      </div>
                    </div>
                  </div>
                </article>
              </div>
            ))}
          </div>
        </div>
        
        <!-- Controles de navegación -->
        <button 
          id="prevBtn"
          class="absolute left-4 top-1/2 transform -translate-y-1/2 bg-white/90 hover:bg-white text-gray-800 p-3 rounded-full shadow-lg hover:shadow-xl transition-all duration-300 z-10"
          onclick="previousSlide()">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
        </button>
        
        <button 
          id="nextBtn"
          class="absolute right-4 top-1/2 transform -translate-y-1/2 bg-white/90 hover:bg-white text-gray-800 p-3 rounded-full shadow-lg hover:shadow-xl transition-all duration-300 z-10"
          onclick="nextSlide()">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </button>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-8 bg-white/5 rounded-xl backdrop-blur-md border border-white/10 hover:-translate-y-2 transition-all duration-300">
          <div class="flex justify-center text-brand-red mb-6">
            <svg width="48" height="48" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-4">Calidad Garantizada</h3>
          <p class="text-white/80 leading-relaxed">Más de 15 años garantizando la mejor calidad en cada corte</p>
        </div>
        
        <div class="text-center p-8 bg-white/5 rounded-xl backdrop-blur-md border border-white/10 hover:-translate-y-2 transition-all duration-300">
          <div class="flex justify-center text-brand-red mb-6">
            <svg width="48" height="48" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-4">Entregas Rápidas</h3>
          <p class="text-white/80 leading-relaxed">Domicilios en toda la ciudad y área metropolitana</p>
        </div>
        
        <div class="text-center p-8 bg-white/5 rounded-xl backdrop-blur-md border border-white/10 hover:-translate-y-2 transition-all duration-300">
          <div class="flex justify-center text-brand-red mb-6">
            <svg width="48" height="48" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-2-2V10a2 2 0 012-2h8z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-4">Atención Personalizada</h3>
          <p class="text-white/80 leading-relaxed">Asesoría experta para elegir el corte perfecto</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA WhatsApp -->
  <section class="py-16 bg-gradient-to-r from-brand-red to-brand-red-dark text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="mb-8">
        <h2 class="text-4xl font-bold text-white mb-4">¿Listo para hacer tu pedido?</h2>
        <p class="text-xl text-white/90 max-w-2xl mx-auto">Contactanos por WhatsApp y te ayudamos a elegir los mejores cortes</p>
      </div>
      <a href="https://wa.me/5573001234567?text=Hola,%20quiero%20hacer%20un%20pedido%20de%20carnes%20premium" 
         class="inline-flex items-center gap-3 bg-white text-brand-red px-8 py-4 rounded-xl font-bold text-lg hover:bg-gray-100 transition-all duration-300 hover:-translate-y-1 shadow-2xl" 
         target="_blank">
        <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
        </svg>
        Pedir por WhatsApp
      </a>
    </div>
  </section>
</Layout>

<script>
  // Productos data para JavaScript
  const productos = [
    {
      id: 1,
      nombre: "Ribeye Premium",
      descripcion: "Corte premium con excelente marmoleo, perfecto para asados especiales",
      precio: 45000,
      imagen: "/Assets/Banner_1.webp",
      categoria: "premium"
    },
    {
      id: 2,
      nombre: "Filete de Res",
      descripcion: "El corte más tierno, ideal para preparaciones gourmet",
      precio: 52000,
      imagen: "/Assets/Banner_1.webp",
      categoria: "premium"
    },
    {
      id: 3,
      nombre: "New York Strip",
      descripcion: "Corte jugoso con el equilibrio perfecto entre textura y sabor",
      precio: 48000,
      imagen: "/Assets/Banner_1.webp",
      categoria: "premium"
    },
    {
      id: 4,
      nombre: "Tomahawk Steak",
      descripcion: "Corte espectacular para ocasiones especiales, presentación única",
      precio: 85000,
      imagen: "/Assets/Banner_1.webp",
      categoria: "especial"
    },
    {
      id: 5,
      nombre: "Picada Premium",
      descripcion: "Selección de los mejores cortes para compartir (4-6 personas)",
      precio: 120000,
      imagen: "/Assets/Banner_1.webp",
      categoria: "combo"
    },
    {
      id: 6,
      nombre: "Asado Familiar",
      descripcion: "Kit completo para asado familiar con acompañamientos",
      precio: 150000,
      imagen: "/Assets/Banner_1.webp",
      categoria: "combo"
    }
  ];

  // Carrito de compras
  let carrito = [];

  function addProductToCart(productId) {
    const producto = productos.find(p => p.id === productId);
    if (producto) {
      const existingItem = carrito.find(item => item.id === productId);
      
      if (existingItem) {
        existingItem.cantidad += 1;
      } else {
        carrito.push({...producto, cantidad: 1});
      }
      
      updateCartDisplay();
      showNotification(`${producto.nombre} agregado al pedido`);
    }
  }

  function updateCartDisplay() {
    const cartCount = carrito.reduce((total, item) => total + item.cantidad, 0);
    const cartCountElement = document.getElementById('cartCount');
    if (cartCountElement) {
      cartCountElement.textContent = cartCount.toString();
    }
  }

  function showNotification(message) {
    // Crear notificación temporal
    const notification = document.createElement('div');
    notification.className = 'notification';
    notification.textContent = message;
    notification.style.cssText = `
      position: fixed;
      top: 100px;
      right: 20px;
      background: var(--brand-red);
      color: white;
      padding: 1rem 1.5rem;
      border-radius: var(--border-radius);
      box-shadow: var(--shadow-lg);
      z-index: 1001;
      animation: slideIn 0.3s ease;
    `;
    
    document.body.appendChild(notification);
    
    setTimeout(() => {
      notification.remove();
    }, 3000);
  }

  function openProductModal(productId) {
    const producto = productos.find(p => p.id === productId);
    if (producto) {
      const whatsappMessage = `Hola, me interesa el ${producto.nombre} por $${producto.precio.toLocaleString('es-CO')}. ¿Podrían darme más información?`;
      const whatsappUrl = `https://wa.me/5573001234567?text=${encodeURIComponent(whatsappMessage)}`;
      window.open(whatsappUrl, '_blank');
    }
  }

  // New Hero Functions
  function scrollToProducts() {
    document.getElementById('productos')?.scrollIntoView({
      behavior: 'smooth',
      block: 'start'
    });
  }

  function openWhatsApp() {
    const whatsappMessage = 'Hola, me interesan sus cortes premium. ¿Podrían ayudarme a elegir el mejor para mi ocasión especial?';
    const whatsappUrl = `https://wa.me/5573001234567?text=${encodeURIComponent(whatsappMessage)}`;
    window.open(whatsappUrl, '_blank');
  }

  // Carrusel Functions
  let currentSlide = 0;
  const totalSlides = 5; // Número de combos

  function nextSlide() {
    currentSlide = (currentSlide + 1) % totalSlides;
    updateCarousel();
  }

  function previousSlide() {
    currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
    updateCarousel();
  }

  function goToSlide(index) {
    currentSlide = index;
    updateCarousel();
  }

  function updateCarousel() {
    const carousel = document.getElementById('combosCarousel');
    if (carousel) {
      carousel.style.transform = `translateX(-${currentSlide * 100}%)`;
    }
    
    // Actualizar indicadores
    for (let i = 0; i < totalSlides; i++) {
      const dot = document.getElementById(`dot-${i}`);
      if (dot) {
        if (i === currentSlide) {
          dot.className = 'w-3 h-3 rounded-full transition-colors duration-300 bg-brand-red';
        } else {
          dot.className = 'w-3 h-3 rounded-full transition-colors duration-300 bg-gray-300';
        }
      }
    }
  }

  // Auto-play del carrusel (opcional)
  setInterval(() => {
    nextSlide();
  }, 5000); // Cambia cada 5 segundos

  // Smooth scrolling para enlaces internos
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        target.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    });
  });

  // Agregar estilos para animaciones
  const style = document.createElement('style');
  style.textContent = `
    @keyframes slideIn {
      from {
        transform: translateX(100%);
        opacity: 0;
      }
      to {
        transform: translateX(0);
        opacity: 1;
      }
    }
  `;
  document.head.appendChild(style);
</script>

