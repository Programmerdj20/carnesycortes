            <!-- Precio y Acción -->
            <div class="border-t pt-6 mt-6">
              <div class="flex items-center justify-between mb-4">
                <div>
                  <span id="modalPrice" class="text-3xl font-bold text-brand-red">$45.000</span>
                  <span class="text-gray-500 ml-2">por unidad</span>
                </div>
                <div class="text-right">
                  <p class="text-sm text-gray-500">Entrega inmediata</p>
                  <p class="text-sm text-green-600 font-semibold">En stock</p>
                </div>
              </div>
              
              <button onclick="addProductToCart(1)" 
                      class="w-full bg-brand-red text-white py-3 px-6 rounded-lg font-semibold hover:bg-brand-red-dark transition-colors">
