</Layout>

<script>
  // Productos data para JavaScript
  const productos = [
    {
      id: 1,
      nombre: "Ribeye Premium",
      descripcion: "Corte premium con excelente marmoleo, perfecto para asados especiales",
      precio: 45000,
      imagen: "/Assets/Banner_1.webp",
      categoria: "premium"
    },
    {
      id: 2,
      nombre: "Filete de Res",
      descripcion: "El corte más tierno, ideal para preparaciones gourmet",
      precio: 52000,
      imagen: "/Assets/Banner_1.webp",
      categoria: "premium"
    },
    {
      id: 3,
      nombre: "New York Strip",
      descripcion: "Corte jugoso con el equilibrio perfecto entre textura y sabor",
      precio: 48000,
      imagen: "/Assets/Banner_1.webp",
      categoria: "premium"
    },
    {
      id: 4,
      nombre: "Tomahawk Steak",
      descripcion: "Corte espectacular para ocasiones especiales, presentación única",
      precio: 85000,
      imagen: "/Assets/Banner_1.webp",
      categoria: "especial"
    },
    {
      id: 5,
      nombre: "Picada Premium",
      descripcion: "Selección de los mejores cortes para compartir (4-6 personas)",
      precio: 120000,
      imagen: "/Assets/Banner_1.webp",
      categoria: "combo"
    },
    {
      id: 6,
      nombre: "Asado Familiar",
      descripcion: "Kit completo para asado familiar con acompañamientos",
      precio: 150000,
      imagen: "/Assets/Banner_1.webp",
      categoria: "combo"
    }
  ];

  // Hacer productos disponible globalmente
  window.productos = productos;

  // Carrito de compras
  let carrito = [];

  function addProductToCart(productId) {
    const producto = productos.find(p => p.id === productId);
    if (producto) {
      // Usar función global del carrito
      window.addToGlobalCart(producto);
      showNotification(`${producto.nombre} agregado al pedido`);
    }
  }

  function updateCartDisplay() {
    const cartCount = carrito.reduce((total, item) => total + item.cantidad, 0);
    const cartCountElement = document.getElementById('cartCount');
    if (cartCountElement) {
      cartCountElement.textContent = cartCount.toString();
    }
  }

  function showNotification(message) {
    // Crear notificación temporal
    const notification = document.createElement('div');
    notification.className = 'notification';
    notification.textContent = message;
    notification.style.cssText = `
      position: fixed;
      top: 100px;
      right: 20px;
      background: var(--brand-red);
      color: white;
      padding: 1rem 1.5rem;
      border-radius: var(--border-radius);
      box-shadow: var(--shadow-lg);
      z-index: 1001;
      animation: slideIn 0.3s ease;
    `;
    
    document.body.appendChild(notification);
    
    setTimeout(() => {
      notification.remove();
    }, 3000);
  }

  // Hacer funciones globales
  window.openProductModal = function(productId) {
    const producto = productos.find(p => p.id === productId);
    if (producto) {
      // Actualizar contenido del modal
      document.getElementById('modalTitle').textContent = producto.nombre;
      document.getElementById('modalDescription').textContent = producto.descripcion;
      document.getElementById('modalPrice').textContent = `$${producto.precio.toLocaleString('es-CO')}`;
      document.getElementById('modalImage').src = producto.imagen;
      document.getElementById('modalImage').alt = producto.nombre;
      
      // Mostrar modal
      const modal = document.getElementById('productModal');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }
  };

  window.closeProductModal = function() {
    const modal = document.getElementById('productModal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = 'auto';
  };

  window.contactWhatsApp = function(productId) {
    const producto = productos.find(p => p.id === productId);
    if (producto) {
      const whatsappMessage = `Hola, me interesa el ${producto.nombre} por $${producto.precio.toLocaleString('es-CO')}. ¿Podrían darme más información?`;
      const whatsappUrl = `https://wa.me/5573001234567?text=${encodeURIComponent(whatsappMessage)}`;
      window.open(whatsappUrl, '_blank');
    }
  };

  // Cerrar modal al hacer clic fuera de él
  document.getElementById('productModal')?.addEventListener('click', function(e) {
    if (e.target === this) {
      window.closeProductModal();
    }
  });

  // New Hero Functions
  function scrollToProducts() {
    document.getElementById('productos')?.scrollIntoView({
      behavior: 'smooth',
      block: 'start'
    });
  }

  function openWhatsApp() {
    const whatsappMessage = 'Hola, me interesan sus cortes premium. ¿Podrían ayudarme a elegir el mejor para mi ocasión especial?';
    const whatsappUrl = `https://wa.me/5573001234567?text=${encodeURIComponent(whatsappMessage)}`;
    window.open(whatsappUrl, '_blank');
  }

  // Carrusel Functions
  let currentSlide = 0;
  const totalSlides = 5; // Número de combos

  function nextSlide() {
    currentSlide = (currentSlide + 1) % totalSlides;
    updateCarousel();
  }

  function previousSlide() {
    currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
    updateCarousel();
  }

  function goToSlide(index) {
    currentSlide = index;
    updateCarousel();
  }

  function updateCarousel() {
    const carousel = document.getElementById('combosCarousel');
    if (carousel) {
      carousel.style.transform = `translateX(-${currentSlide * 100}%)`;
    }
    
    // Actualizar indicadores
    for (let i = 0; i < totalSlides; i++) {
      const dot = document.getElementById(`dot-${i}`);
      if (dot) {
        if (i === currentSlide) {
          dot.className = 'w-3 h-3 rounded-full transition-colors duration-300 bg-brand-red';
        } else {
          dot.className = 'w-3 h-3 rounded-full transition-colors duration-300 bg-gray-300';
        }
      }
    }
  }

  // Auto-play del carrusel (opcional)
  setInterval(() => {
    nextSlide();
  }, 5000); // Cambia cada 5 segundos

  // Smooth scrolling para enlaces internos
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        target.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    });
  });

  // Agregar estilos para animaciones
  const style = document.createElement('style');
  style.textContent = `
    @keyframes slideIn {
      from {
        transform: translateX(100%);
        opacity: 0;
      }
      to {
        transform: translateX(0);
        opacity: 1;
      }
    }
  `;
  document.head.appendChild(style);
</script>

