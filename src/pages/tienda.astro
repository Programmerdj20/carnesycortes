      precio: 18000,
      imagen: "/Assets/Banner_1.webp",
      categoria: "especialidad",
      peso: "400g"
    }
  ];

  // Usar el carrito global del layout
  let cart = window.globalCart || [];

  // Funciones del carrito
  function addToCart(productId) {
    const producto = productos.find(p => p.id === productId);
    if (producto) {
      // Usar función global del carrito
      window.addToGlobalCart(producto);
      
      // Sincronizar carrito local
      cart = window.globalCart;
      updateCartDisplay();
      showNotification(`${producto.nombre} agregado al carrito`);
    }
  }

  function removeFromCart(productId) {
    cart = cart.filter(item => item.id !== productId);
    updateCartDisplay();
  }

  function updateQuantity(productId, change) {
    // Usar función global
    window.updateGlobalQuantity(productId, change);
    
    // Sincronizar carrito local
    cart = window.globalCart;
    updateCartDisplay();
  }

  function updateCartDisplay() {
    // Sincronizar con carrito global
    cart = window.globalCart;
    
    const cartCount = cart.reduce((total, item) => total + item.cantidad, 0);
    const cartTotal = cart.reduce((total, item) => total + (item.precio * item.cantidad), 0);
    
    // Actualizar contador del carrito local de la tienda
    const cartItemCountElement = document.getElementById('cartItemCount');
    const cartTotalElement = document.getElementById('cartTotal');
    
    if (cartItemCountElement) cartItemCountElement.textContent = cartCount;
    if (cartTotalElement) cartTotalElement.textContent = `$${cartTotal.toLocaleString('es-CO')}`;
    
    // Actualizar lista de productos en el carrito
    const cartItems = document.getElementById('cartItems');
    
    if (cartItems) {
      if (cart.length === 0) {
        cartItems.innerHTML = `
          <div class="text-center text-gray-500 py-8">
            <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4m2.6 8L6 5H2m5 8v6a1 1 0 001 1h10a1 1 0 001-1v-6m-9 0V9a1 1 0 011-1h4a1 1 0 011 1v4"></path>
            </svg>
            <p>Tu carrito está vacío</p>
            <p class="text-sm mt-2">¡Agrega algunos productos deliciosos!</p>
          </div>
        `;
        const checkoutBtn = document.getElementById('checkoutBtn');
        if (checkoutBtn) checkoutBtn.disabled = true;
      } else {
        cartItems.innerHTML = cart.map(item => `
          <div class="flex items-center gap-4 p-4 border border-gray-200 rounded-lg mb-4">
            <img src="${item.imagen}" alt="${item.nombre}" class="w-16 h-16 object-cover rounded-lg">
            <div class="flex-1">
              <h4 class="font-semibold text-gray-900">${item.nombre}</h4>
              <p class="text-sm text-gray-600">${item.peso}</p>
              <p class="text-brand-red font-bold">$${item.precio.toLocaleString('es-CO')}</p>
            </div>
            <div class="flex items-center gap-2">
              <button onclick="updateQuantity(${item.id}, -1)" class="w-8 h-8 bg-gray-200 text-gray-700 rounded-full flex items-center justify-center hover:bg-gray-300 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path>
                </svg>
              </button>
              <span class="w-8 text-center font-semibold">${item.cantidad}</span>
              <button onclick="updateQuantity(${item.id}, 1)" class="w-8 h-8 bg-brand-red text-white rounded-full flex items-center justify-center hover:bg-brand-red-dark transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                </svg>
              </button>
            </div>
          </div>
        `).join('');
        const checkoutBtn = document.getElementById('checkoutBtn');
        if (checkoutBtn) checkoutBtn.disabled = false;
      }
    }
  }

  function toggleCart() {
    const cartPanel = document.getElementById('cartPanel');
    cartPanel.classList.toggle('hidden');
  }

  function filterProducts(category) {
    const productCards = document.querySelectorAll('.product-card');
    const filterBtns = document.querySelectorAll('.filter-btn');
    
    // Actualizar botones activos
    filterBtns.forEach(btn => {
      btn.classList.remove('border-brand-red', 'text-brand-red', 'bg-brand-red/5');
      btn.classList.add('border-gray-200', 'text-gray-700');
    });
    
    const activeBtn = document.querySelector(`[data-category="${category}"]`);
    activeBtn.classList.remove('border-gray-200', 'text-gray-700');
    activeBtn.classList.add('border-brand-red', 'text-brand-red', 'bg-brand-red/5');
    
    // Filtrar productos
    productCards.forEach(card => {
      if (category === 'todos' || card.dataset.category === category) {
        card.style.display = 'block';
      } else {
        card.style.display = 'none';
      }
    });
  }

  function sendWhatsAppOrder() {
    if (cart.length === 0) return;
    
    let message = "🥩 *PEDIDO CARNES & CORTES*\n\n";
    message += "📋 *Productos:*\n";
    
    cart.forEach(item => {
      message += `• ${item.nombre} (${item.peso})\n`;
      message += `  Cantidad: ${item.cantidad}\n`;
      message += `  Precio: $${item.precio.toLocaleString('es-CO')} c/u\n`;
      message += `  Subtotal: $${(item.precio * item.cantidad).toLocaleString('es-CO')}\n\n`;
    });
    
    const total = cart.reduce((total, item) => total + (item.precio * item.cantidad), 0);
    message += `💰 *Total: $${total.toLocaleString('es-CO')}*\n\n`;
    message += "📍 Por favor confirmen disponibilidad y tiempo de entrega.";
    
    const whatsappUrl = `https://wa.me/5573001234567?text=${encodeURIComponent(message)}`;
    window.open(whatsappUrl, '_blank');
  }

  function showNotification(message) {
    const notification = document.createElement('div');
    notification.className = 'fixed top-4 right-4 bg-green-600 text-white px-6 py-3 rounded-lg shadow-lg z-50 animate-fade-in-down';
    notification.textContent = message;
    
    document.body.appendChild(notification);
    
    setTimeout(() => {
      notification.remove();
    }, 3000);
  }

  // Inicializar filtro
  document.addEventListener('DOMContentLoaded', function() {
    // Marcar "Todos" como activo al inicio
    const todosBtn = document.querySelector('[data-category="todos"]');
    todosBtn.classList.add('border-brand-red', 'text-brand-red', 'bg-brand-red/5');
    todosBtn.classList.remove('border-gray-200', 'text-gray-700');
  });

  // Hacer funciones globales
  window.addToCart = addToCart;
  window.removeFromCart = removeFromCart;
  window.updateQuantity = updateQuantity;
  window.toggleCart = toggleCart;
  window.filterProducts = filterProducts;
  window.sendWhatsAppOrder = sendWhatsAppOrder;
</script>

<style>
  .animate-fade-in-down {
    animation: fadeInDown 0.3s ease-out;
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>