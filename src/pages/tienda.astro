---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const productos = await getCollection('productos');

const categorias = [
  { id: 'todos', nombre: 'Todos', icono: '🥩' },
  { id: 'premium', nombre: 'Premium', icono: '⭐' },
  { id: 'tradicional', nombre: 'Tradicionales', icono: '🔥' },
  { id: 'combo', nombre: 'Combos', icono: '👨‍👩‍👧‍👦' },
  { id: 'especial', nombre: 'Especiales', icono: '👑' },
  { id: 'especialidad', nombre: 'Especialidades', icono: '🎯' },
];
---

<Layout title="Tienda - Carnes & Cortes" currentPath="/tienda">
  <!-- Hero compacto -->
  <section class="bg-dark-900 pt-28 pb-12 relative overflow-hidden">
    <div class="absolute inset-0 opacity-30">
      <img src="https://images.unsplash.com/photo-1544025162-d76694265947?w=1600&q=60" alt="" class="w-full h-full object-cover" loading="eager" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-dark-900/80 to-dark-900"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[
        { label: 'Inicio', href: '/' },
        { label: 'Tienda' },
      ]} />
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-white mt-4">Nuestra Tienda</h1>
      <p class="text-gray-400 mt-2 max-w-lg">Explora nuestra selección completa de cortes premium y especialidades</p>
    </div>
  </section>

  <!-- Filtros -->
  <section class="sticky top-[72px] z-30 bg-white border-b border-gray-100 shadow-premium-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 py-4 overflow-x-auto scrollbar-hide">
        {categorias.map(cat => (
          <button
            onclick={`filterProducts('${cat.id}')`}
            class="filter-btn flex items-center gap-2 px-5 py-2.5 rounded-full font-medium text-sm whitespace-nowrap transition-all duration-300 border"
            data-category={cat.id}>
            <span>{cat.icono}</span>
            <span>{cat.nombre}</span>
          </button>
        ))}

        <!-- Separator -->
        <div class="w-px h-8 bg-gray-200 mx-2 flex-shrink-0"></div>

        <!-- Ordenar -->
        <select id="sortSelect" onchange="sortProducts(this.value)" class="px-4 py-2.5 rounded-full border border-gray-200 text-sm text-gray-600 bg-white focus:outline-none focus:border-brand-red cursor-pointer">
          <option value="default">Ordenar por</option>
          <option value="price-asc">Precio: Menor a Mayor</option>
          <option value="price-desc">Precio: Mayor a Menor</option>
          <option value="name">Nombre A-Z</option>
        </select>
      </div>
    </div>
  </section>

  <!-- Grid de Productos -->
  <section class="py-12 bg-cream min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Contador de resultados -->
      <div class="flex items-center justify-between mb-8">
        <p class="text-gray-500 text-sm" id="resultCount">
          Mostrando <span class="font-semibold text-gray-900">{productos.length}</span> productos
        </p>
      </div>

      <div id="productGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {productos.map(producto => (
          <ProductCard
            id={producto.data.id}
            nombre={producto.data.nombre}
            descripcion={producto.data.descripcion}
            precio={producto.data.precio}
            imagen={producto.data.imagen}
            categoria={producto.data.categoria}
            peso={producto.data.peso}
            slug={producto.data.slug}
            destacado={producto.data.destacado}
          />
        ))}
      </div>

      <!-- Empty state -->
      <div id="emptyState" class="hidden text-center py-16">
        <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <p class="text-gray-500 font-medium">No se encontraron productos en esta categoría</p>
      </div>
    </div>
  </section>
</Layout>

<script>
  let activeCategory = 'todos';

  function filterProducts(category) {
    activeCategory = category;
    const cards = document.querySelectorAll('.product-card');
    const filterBtns = document.querySelectorAll('.filter-btn');

    // Update active button
    filterBtns.forEach(btn => {
      const isActive = btn.dataset.category === category;
      btn.classList.toggle('bg-brand-red', isActive);
      btn.classList.toggle('text-white', isActive);
      btn.classList.toggle('border-brand-red', isActive);
      btn.classList.toggle('bg-white', !isActive);
      btn.classList.toggle('text-gray-600', !isActive);
      btn.classList.toggle('border-gray-200', !isActive);
      btn.classList.toggle('hover:border-brand-red', !isActive);
    });

    // Filter cards
    let visibleCount = 0;
    cards.forEach(card => {
      const show = category === 'todos' || card.dataset.category === category;
      card.style.display = show ? '' : 'none';
      if (show) visibleCount++;
    });

    // Update count
    const resultCount = document.getElementById('resultCount');
    if (resultCount) {
      resultCount.innerHTML = `Mostrando <span class="font-semibold text-gray-900">${visibleCount}</span> productos`;
    }

    // Empty state
    const emptyState = document.getElementById('emptyState');
    const grid = document.getElementById('productGrid');
    if (emptyState && grid) {
      emptyState.classList.toggle('hidden', visibleCount > 0);
    }
  }

  function sortProducts(sortBy) {
    const grid = document.getElementById('productGrid');
    if (!grid) return;

    const cards = Array.from(grid.querySelectorAll('.product-card'));

    cards.sort((a, b) => {
      const nameA = a.querySelector('h3')?.textContent || '';
      const nameB = b.querySelector('h3')?.textContent || '';
      const priceA = parseInt(a.querySelector('.text-brand-red')?.textContent?.replace(/\D/g, '') || '0');
      const priceB = parseInt(b.querySelector('.text-brand-red')?.textContent?.replace(/\D/g, '') || '0');

      switch (sortBy) {
        case 'price-asc': return priceA - priceB;
        case 'price-desc': return priceB - priceA;
        case 'name': return nameA.localeCompare(nameB);
        default: return 0;
      }
    });

    cards.forEach(card => grid.appendChild(card));
  }

  // Init: check URL params for category filter
  document.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const cat = params.get('cat');
    if (cat) {
      filterProducts(cat);
    } else {
      filterProducts('todos');
    }
  });

  window.filterProducts = filterProducts;
  window.sortProducts = sortProducts;
</script>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
