<Layout title="Tienda - Carnes & Cortes">
  <!-- Hero de Tienda -->
  <section class="bg-gradient-to-br from-brand-red to-brand-red-dark text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black mb-6">Nuestra Tienda</h1>
      <p class="text-xl text-white/90 max-w-2xl mx-auto mb-8">
        Explora nuestra selección completa de cortes premium y especialidades
      </p>
      <!-- Carrito flotante -->
      <div class="fixed top-32 right-4 z-40 bg-white rounded-lg shadow-xl p-4 border border-brand-red/20" id="cartWidget">
        <div class="flex items-center gap-3">
          <svg class="w-6 h-6 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4m2.6 8L6 5H2m5 8v6a1 1 0 001 1h10a1 1 0 001-1v-6m-9 0V9a1 1 0 011-1h4a1 1 0 011 1v4"></path>
          </svg>
          <div>
            <div class="text-sm font-semibold text-gray-900">Carrito</div>
            <div class="text-xs text-gray-600"><span id="cartItemCount">0</span> productos</div>
          </div>
          <button onclick="toggleCart()" class="ml-2 bg-brand-red text-white px-3 py-1 rounded text-sm hover:bg-brand-red-dark transition-colors">
            Ver
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Filtros de Categorías -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap justify-center gap-4 lg:gap-6">
        {categorias.map(categoria => (
          <button 
            onclick={`filterProducts('${categoria.id}')`}
            class="filter-btn flex items-center gap-2 lg:gap-3 px-4 lg:px-6 py-3 lg:py-4 bg-white border-2 border-gray-200 rounded-xl font-semibold text-gray-700 hover:border-brand-red hover:text-brand-red transition-all duration-300 shadow-sm hover:shadow-md text-sm lg:text-base"
            data-category={categoria.id}>
            <span class="text-lg lg:text-xl">{categoria.icono}</span>
            <span class="whitespace-nowrap">{categoria.nombre}</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Grid de Productos -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div id="productGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
        {productos.map(producto => (
          <article class="product-card bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100" data-category={producto.categoria}>
            <div class="relative group overflow-hidden aspect-[4/3]">
              <img src={producto.imagen} alt={producto.nombre} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
              <div class="absolute inset-0 bg-black/70 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <button class="bg-brand-red text-white px-6 py-3 rounded-lg font-semibold hover:bg-brand-red-dark transition-colors duration-300" onclick={`openProductModal(${producto.id})`}>
                  Ver Detalles
                </button>
              </div>
              <span class="absolute top-4 left-4 bg-brand-red text-white px-3 py-1 rounded-lg text-sm font-bold capitalize">
                {producto.categoria}
              </span>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">{producto.nombre}</h3>
              <p class="text-gray-600 mb-3 leading-relaxed text-sm">{producto.descripcion}</p>
              <div class="flex items-center justify-between mb-4">
                <div>
                  <span class="text-2xl font-bold text-brand-red">
                    ${producto.precio.toLocaleString('es-CO')}
                  </span>
                  <div class="text-sm text-gray-500">{producto.peso}</div>
                </div>
              </div>
              <button class="w-full flex items-center justify-center gap-2 bg-brand-red text-white px-4 py-3 rounded-lg font-semibold hover:bg-brand-red-dark transition-all duration-300 hover:-translate-y-0.5" onclick={`addToCart(${producto.id})`}>
                <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                </svg>
                Agregar al Carrito
              </button>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Panel del Carrito -->
  <div id="cartPanel" class="fixed inset-0 bg-black/50 z-50 hidden">
    <div class="fixed right-0 top-0 h-full w-full max-w-md bg-white shadow-xl">
      <div class="flex flex-col h-full">
        <!-- Header del Carrito -->
        <div class="p-6 border-b border-gray-200">
          <div class="flex items-center justify-between">
            <h2 class="text-2xl font-bold text-gray-900">Mi Carrito</h2>
            <button onclick="toggleCart()" class="text-gray-400 hover:text-gray-600">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
          <p class="text-gray-600 mt-1">Productos seleccionados</p>
        </div>

        <!-- Lista de productos del carrito -->
        <div class="flex-1 overflow-y-auto p-6" id="cartItems">
          <div class="text-center text-gray-500 py-8">
            <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4m2.6 8L6 5H2m5 8v6a1 1 0 001 1h10a1 1 0 001-1v-6m-9 0V9a1 1 0 011-1h4a1 1 0 011 1v4"></path>
            </svg>
            <p>Tu carrito está vacío</p>
            <p class="text-sm mt-2">¡Agrega algunos productos deliciosos!</p>
          </div>
        </div>

        <!-- Footer del Carrito -->
        <div class="border-t border-gray-200 p-6">
          <div class="flex items-center justify-between mb-4">
            <span class="text-lg font-semibold text-gray-900">Total:</span>
            <span class="text-2xl font-bold text-brand-red" id="cartTotal">$0</span>
          </div>
          <button onclick="sendWhatsAppOrder()" class="w-full bg-green-600 text-white py-3 px-6 rounded-lg font-semibold hover:bg-green-700 transition-colors flex items-center justify-center gap-2" id="checkoutBtn" disabled>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
            </svg>
            Hacer Pedido por WhatsApp
          </button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Productos data para JavaScript
  const productos = [
